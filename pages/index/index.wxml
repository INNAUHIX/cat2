<navigation-bar title="保险箱" showBack="{{false}}"></navigation-bar>
<view class="page">
  <view class="content">
    <view class="pet-header" bindtap="onAddPetTap" wx:if="{{petImage}}">
      <image class="pet-header-image" src="{{petImage}}" mode="aspectFill"></image>
      <view class="pet-info-overlay">
        <text class="pet-info-name">{{petName}}</text>
        <text class="pet-info-days">{{daysWithPet}}天陪伴</text>
      </view>
    </view>
    <view class="add-pet-header" bindtap="onAddPetTap" wx:else>
      <view class="entry-title-row">
        <text class="entry-title">添加宠物</text>
        <view class="add-icon" aria-role="button" aria-label="添加宠物"></view>
      </view>
      <text class="entry-desc">创建第一只宠物，记录它的每一个细节</text>
    </view>

    <view class="feature-grid">
      <view class="feature-block">
        <text class="feature-title">消费记录</text>
        <text class="feature-subtitle">消费记账 多维报表</text>
        <view class="feature-bars">
          <view class="feature-bar"></view>
          <view class="feature-bar"></view>
          <view class="feature-bar"></view>
          <view class="feature-bar"></view>
          <view class="feature-bar"></view>
          <view class="feature-bar"></view>
          <view class="feature-bar"></view>
        </view>
      </view>
      <view class="feature-block">
        <text class="feature-title">体重管理</text>
        <text class="feature-subtitle">体重记录 趋势分析</text>
        <view class="weight-trend">
          <view class="weight-trend-fill"></view>
        </view>
      </view>
    </view>
  </view>
</view>
