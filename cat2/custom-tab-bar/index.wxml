<view class="tab-bar">
  <view class="tab-bar-item" wx:for="{{list}}" wx:key="pagePath" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <image class="tab-bar-icon" src="{{selected == index ? item.selectedIconPath + '?t=1' : item.iconPath + '?t=0'}}"></image>
    <text class="tab-bar-text {{selected == index ? 'active' : ''}}">{{item.text}}</text>
  </view>
</view>
