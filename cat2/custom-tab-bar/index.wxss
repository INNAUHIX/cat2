.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  z-index: 999;
}

.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  flex: 1;
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-bar-text {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #B0B0B0;
}

.tab-bar-text.active {
  color: #333333;
}
