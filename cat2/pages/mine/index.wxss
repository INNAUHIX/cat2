page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F7F7F7;
}

.page {
  flex: 1;
  min-height: 0;
}

.content {
  padding: 16rpx 24rpx 0;
}

/* 宠物卡片 */
.pet-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 22px;
  box-shadow: 0px 2px 16px 2px rgba(0, 0, 0, 0.04);
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex: none;
}

.pet-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.pet-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
  line-height: 1.3;
}

.pet-breed {
  font-size: 24rpx;
  color: #a3a3a3;
  margin-top: 6rpx;
}

.edit-btn {
  flex: none;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666666;
  background: #f5f5f5;
  border-radius: 32rpx;
}

/* 空状态卡片 */
.add-pet-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
  background: #ffffff;
  border-radius: 22px;
  box-shadow: 0px 2px 16px 2px rgba(0, 0, 0, 0.04);
}

.add-pet-card .add-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  position: relative;
}

.add-pet-card .add-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 28rpx;
  background: #b0b0b0;
  transform: translate(-50%, -50%);
}

.add-pet-card .add-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 28rpx;
  height: 4rpx;
  background: #b0b0b0;
  transform: translate(-50%, -50%);
}

.add-text {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.add-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #a3a3a3;
}

/* 菜单 */
.menu-section {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 22px;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.menu-item + .menu-item {
  border-top: 1rpx solid #f5f5f5;
}

.menu-label {
  font-size: 28rpx;
  color: #1f1f1f;
}

.menu-arrow {
  font-size: 32rpx;
  color: #c0c0c0;
}
