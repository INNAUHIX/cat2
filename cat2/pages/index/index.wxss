page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F7F7F7;
}

.page {
  flex: 1;
  min-height: 0;
}

.content {
  padding: 16rpx 24rpx 0;
}

.pet-header {
  position: relative;
  width: 100%;
  height: 386rpx;
  border-radius: 22px;
  overflow: hidden;
  box-shadow: 0px 2px 16.6px 2px rgba(0, 0, 0, 0.01);
}

.pet-header-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.pet-info-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.pet-info-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.pet-info-days {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.add-pet-header {
  padding: 8rpx 6rpx 0;
}

.entry-title-row {
  display: flex;
  align-items: center;
}

.entry-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1f1f1f;
  line-height: 1.15;
}

.add-icon {
  width: 44rpx;
  height: 44rpx;
  margin-left: 18rpx;
  display: block;
  flex: none;
  position: relative;
}

.add-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 28rpx;
  background: #000000;
  transform: translate(-50%, -50%);
}

.add-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 28rpx;
  height: 4rpx;
  background: #000000;
  transform: translate(-50%, -50%);
}

.entry-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #787878;
}

.feature-grid {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.feature-block {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  flex-direction: column;
  flex: 1;
  aspect-ratio: 1 / 1;
  padding: 32rpx;
  box-sizing: border-box;
  border-radius: 44rpx;
  background: #ffffff;
}

.feature-title {
  flex: none;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #1f1f1f;
}

.feature-subtitle {
  flex: none;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  min-height: 32rpx;
  color: #a3a3a3;
}

.feature-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  width: 100%;
  margin-top: auto;
  padding-top: 36rpx;
  box-sizing: border-box;
}

.feature-bar {
  width: 20rpx;
  height: 108rpx;
  border-radius: 8rpx;
  background: #ececec;
  flex: none;
}

.weight-trend {
  width: 100%;
  margin-top: auto;
  height: 108rpx;
  overflow: hidden;
}

.weight-trend-fill {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #e5fcf1 0%, rgba(229, 252, 241, 0) 100%);
}
