.nav-bar {
  width: 100%;
}

.nav-bar__status {
  width: 100%;
}

.nav-bar__content {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.nav-bar__left {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.nav-bar__back {
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 48rpx;
  height: 48rpx;
}

.nav-bar__title {
  flex: 1;
  text-align: center;
  font-size: 16px;
  font-weight: 400;
  line-height: 44px;
  color: #000000;
}

.nav-bar__right {
  width: 80rpx;
}